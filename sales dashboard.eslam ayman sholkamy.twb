      <column caption='sales avg' datatype='string' name='[Calculation_2107275268980740]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([SALES])&gt;WINDOW_AVG(SUM([SALES]))THEN&#13;&#10;&apos;above avg&apos;ELSE&apos;below avg&apos;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Aov' datatype='real' name='[Calculation_2107275273068549]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SALES])/COUNTD([ORDERNUMBER])' />
      </column>
